{
  "name": "n8n-nodes-flyio",
  "version": "1.0.0",
  "description": "A comprehensive n8n community node for Fly.io providing 8 resources and 50+ operations for managing Fly Apps, Machines (fast-launching VMs), Volumes, Secrets, Certificates, IP Addresses, Organizations, and Regions through the Machines REST API and GraphQL API.",
  "license": "SEE LICENSE IN LICENSE.md",
  "author": {
    "name": "Velocity BPA",
    "email": "licensing@velobpa.com",
    "url": "https://velobpa.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Velocity-BPA/n8n-nodes-flyio.git"
  },
  "homepage": "https://github.com/Velocity-BPA/n8n-nodes-flyio",
  "bugs": {
    "url": "https://github.com/Velocity-BPA/n8n-nodes-flyio/issues"
  },
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "flyio",
    "fly.io",
    "fly",
    "machines",
    "cloud",
    "infrastructure",
    "devops",
    "automation",
    "edge-computing",
    "microvm",
    "firecracker",
    "deployment",
    "containers"
  ],
  "main": "dist/nodes/FlyIo/FlyIo.node.js",
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/FlyIoApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/FlyIo/FlyIo.node.js",
      "dist/nodes/FlyIo/FlyIoTrigger.node.js"
    ]
  },
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.ts\"",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "prepublishOnly": "npm run build",
    "clean": "rimraf dist"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "gulp": "^4.0.2",
    "jest": "^29.7.0",
    "n8n-workflow": "1.57.0",
    "prettier": "^3.2.4",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "n8n-workflow": ">=1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}